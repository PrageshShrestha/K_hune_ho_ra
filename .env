# KHUNEHO? Configuration File
# Copy this to .env and modify as needed

# System Configuration
SYSTEM_NAME=K_HUNE_HO_RA
SYSTEM_VERSION=1.0.0
DEBUG_MODE=false
LOG_LEVEL=INFO

# Model Configuration - Optimized for 16GB VRAM
# Sentiment Analysis
MODEL_SENTIMENT=nlptown/bert-base-multilingual-uncased-sentiment
LABELS_SENTIMENT=1 star,2 stars,3 stars,4 stars,5 stars

# Financial Analysis
MODEL_FINANCIAL=ProsusAI/finbert
LABELS_FINANCIAL=positive,negative,neutral

# Geopolitical Analysis
MODEL_GEOPOLITICAL=BAAI/bge-small-en-v1.5
LABELS_GEOPOLITICAL=stable,tension,conflict,war

# Legal Analysis
MODEL_LEGAL=nlpaueb/legal-bert-base-uncased
LABELS_LEGAL=compliant,gray_area,violation

# Technology Analysis
MODEL_TECHNOLOGICAL=Qwen/Qwen2-0.5B-Instruct
LABELS_TECHNOLOGICAL=disruption,adoption,maturity,obsolescence

# Social Analysis
MODEL_SOCIAL=cardiffnlp/twitter-roberta-base-sentiment-latest
LABELS_SOCIAL=negative,neutral,positive

# Environmental Analysis
MODEL_ENVIRONMENTAL=climatebert/distilroberta-base-climate-sentiment
LABELS_ENVIRONMENTAL=improving,stable,deteriorating

# Health Analysis
MODEL_HEALTH=emilyalsentzer/Bio_ClinicalBERT
LABELS_HEALTH=improving,stable,crisis

# Military Analysis
MODEL_MILITARY=google/gemma-2b-it
LABELS_MILITARY=peace,posturing,skirmish,war

# Economic Analysis
MODEL_ECONOMIC=FinGPT/fingpt-forecaster_dow30
LABELS_ECONOMIC=depression,recession,stable,growth,boom

# Cultural Analysis
MODEL_CULTURAL=xlm-roberta-base
LABELS_CULTURAL=unified,divided,polarized

# Ethical Analysis
MODEL_ETHICAL=microsoft/deberta-v3-base
LABELS_ETHICAL=acceptable,questionable,unacceptable

# Strategic Analysis
MODEL_STRATEGIC=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LABELS_STRATEGIC=retreat,defend,advance,dominate

# Historical Analysis
MODEL_HISTORICAL=sentence-transformers/all-MiniLM-L6-v2
LABELS_HISTORICAL=event_type_0,event_type_1,event_type_2,event_type_3,event_type_4,event_type_5,event_type_6,event_type_7,event_type_8,event_type_9

# Predictive Analysis
MODEL_PREDICTIVE=distilbert-base-uncased
LABELS_PREDICTIVE=unlikely,possible,likely

# Web Search Configuration
SEARCH_ENGINE=duckduckgo
MAX_SEARCH_RESULTS=5
MAX_NEWS_RESULTS=8
SEARCH_TIMEOUT=30

# Weight Calculation Configuration
WEIGHT_KEYWORD_RELEVANCE=0.5
WEIGHT_CONFIDENCE=0.3
WEIGHT_SOURCE_QUALITY=0.2
MIN_NEURON_WEIGHT=0.05

# VRAM Management
MAX_VRAM_USAGE_GB=4.0
UNLOAD_AFTER_USE=true
MEMORY_LOGGING=true

# Conversation Interface
INTERFACE_STYLE=clean
SHOW_PROGRESS=true
SHOW_SYSTEM_INFO=true
MAX_REASONING_LENGTH=500

# Action Mapping Configuration
# Format: NEURON_PREDICTION=Action text
ACTION_SENTIMENT_VERY_NEGATIVE=Prepare crisis communication strategy
ACTION_SENTIMENT_NEGATIVE=Monitor public perception closely
ACTION_SENTIMENT_POSITIVE=Leverage positive sentiment in messaging
ACTION_FINANCIAL_POSITIVE=Consider increasing exposure
ACTION_FINANCIAL_NEGATIVE=Hedge positions, reduce risk
ACTION_FINANCIAL_NEUTRAL=Maintain current strategy
ACTION_GEOPOLITICAL_CONFLICT=Review international operations
ACTION_GEOPOLITICAL_WAR=Activate contingency plans
ACTION_GEOPOLITICAL_TENSION=Increase diplomatic engagement
ACTION_LEGAL_VIOLATION=Conduct compliance audit immediately
ACTION_LEGAL_GRAY_AREA=Seek legal clarification
ACTION_PREDICTIVE_LIKELY=Prepare implementation timeline
ACTION_PREDICTIVE_POSSIBLE=Develop contingency scenarios

# Domain Keywords for Weight Calculation
# Format: KEYWORDS_NEURON=keyword1,keyword2,keyword3
KEYWORDS_SENTIMENT=feeling,public,reaction,emotional,mood
KEYWORDS_FINANCIAL=stock,market,price,investment,trading,dollar
KEYWORDS_GEOPOLITICAL=country,nation,alliance,diplomacy,border
KEYWORDS_LEGAL=law,court,regulation,compliance,lawsuit
KEYWORDS_TECHNOLOGICAL=tech,software,ai,digital,innovation
KEYWORDS_SOCIAL=people,society,protest,movement,community
KEYWORDS_ENVIRONMENTAL=climate,weather,pollution,energy,green
KEYWORDS_HEALTH=disease,pandemic,hospital,vaccine,medical
KEYWORDS_MILITARY=army,weapon,defense,troop,missile
KEYWORDS_ECONOMIC=economy,gdp,inflation,jobs,trade
KEYWORDS_CULTURAL=culture,tradition,religion,art,heritage
KEYWORDS_ETHICAL=moral,right,wrong,justice,fair
KEYWORDS_STRATEGIC=plan,strategy,long-term,positioning
KEYWORDS_HISTORICAL=past,history,precedent,previous
KEYWORDS_PREDICTIVE=future,forecast,trend,outlook
